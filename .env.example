# Cal.com booking link (used for "Book a Call" and CTA buttons)
# The path after cal.com — e.g. "yourname/audit" → https://cal.com/yourname/audit
NEXT_PUBLIC_CAL_LINK=sparkrise/revenue-leak-audit

# n8n webhook URL for contact form submissions (server-side only — never exposed to client)
N8N_WEBHOOK_URL=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
