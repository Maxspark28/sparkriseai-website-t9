# ── AI PROVIDERS ────────────────────────────────────────────────
# OpenAI — required right now (fast tasks + primary fallback)
OPENAI_API_KEY=sk-...

# Anthropic — add when ready (primary tasks auto-upgrade to Claude)
# Get $10 credit at console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# ── ROUTING LOGIC ────────────────────────────────────────────────
# fast tasks  → always OpenAI (gpt-4o-mini)
# primary tasks:
#   ANTHROPIC_API_KEY set   → Claude Opus (claude-opus-4-6)
#   ANTHROPIC_API_KEY unset → OpenAI (gpt-4o)

# ── INTEGRATIONS ─────────────────────────────────────────────────
# n8n Webhook (paste your n8n webhook URL here)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/sparkrise-agents

# Optional: output directory for generated content
OUTPUT_DIR=./output
